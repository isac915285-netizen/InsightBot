<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | InsightBot Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
</head>
<body class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-logo">
                <i class="fas fa-robot"></i>
                <h1>Insight<span>Bot</span></h1>
            </div>
            <p class="login-subtitle">Painel de Controle</p>
            
            <div class="login-description">
                <p>Faça login com Discord para gerenciar seu bot</p>
            </div>
            
            <a href="/auth/discord" class="discord-login-btn">
                <i class="fab fa-discord"></i>
                Entrar com Discord
            </a>
            
            <div class="login-footer">
                <p>Ao fazer login, você concorda com nossos termos</p>
                <p class="login-version">InsightBot v2.1.0</p>
            </div>
        </div>
    </div>
</body>
</html>
