<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InsightBot | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-robot"></i>
                    <span>Insight<span class="highlight">Bot</span></span>
                </div>
                <p class="sidebar-subtitle">Painel de Controle</p>
            </div>
            
            <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-card">
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="Avatar" class="user-avatar">
                <div class="user-info">
                    <h4><%= user.username %></h4>
                    <p>#<%= user.discriminator || '0' %></p>
                </div>
            </div>
            <% } %>
            
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/dashboard/commands" class="nav-item <%= currentPage === 'commands' ? 'active' : '' %>">
                    <i class="fas fa-terminal"></i>
                    <span>Comandos</span>
                </a>
                <a href="/dashboard/stats" class="nav-item <%= currentPage === 'stats' ? 'active' : '' %>">
                    <i class="fas fa-chart-bar"></i>
                    <span>Estatísticas</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Sair</span>
                </a>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <%- body %>
        </div>
    </div>
    
    <script src="/js/dashboard.js"></script>
</body>
</html>
